{
	"name": "all-contributors-for-repository",
	"version": "0.5.1",
	"description": "Generates an allcontributors list for an existing repository. 🤝",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/JoshuaKGoldberg/all-contributors-for-repository.git"
	},
	"license": "MIT",
	"author": {
		"name": "JoshuaKGoldberg",
		"email": "npm@joshuakgoldberg.com"
	},
	"sideEffects": false,
	"type": "module",
	"exports": {
		".": "./lib/index.js"
	},
	"main": "lib/index.js",
	"files": [
		"lib/"
	],
	"scripts": {
		"build": "tsdown",
		"format": "prettier .",
		"lint": "eslint . --max-warnings 0",
		"lint:knip": "knip",
		"lint:packages": "pnpm dedupe --check",
		"lint:spelling": "cspell \"**\" \".github/**/*\"",
		"prepare": "husky",
		"test": "vitest",
		"tsc": "tsc"
	},
	"lint-staged": {
		"*": "prettier --ignore-unknown --write"
	},
	"dependencies": {
		"co-author-to-username": "^0.1.3",
		"conventional-commits-parser": "^7.0.0",
		"description-to-co-authors": "^0.3.0",
		"octokit": "^5.0.3",
		"octokit-from-auth": "^0.3.2"
	},
	"devDependencies": {
		"@eslint-community/eslint-plugin-eslint-comments": "4.7.0",
		"@eslint/js": "10.0.1",
		"@eslint/markdown": "8.0.2",
		"@release-it/conventional-changelog": "11.0.0",
		"@types/conventional-commits-parser": "5.0.1",
		"@types/node": "24.13.0",
		"@vitest/coverage-v8": "4.1.0",
		"@vitest/eslint-plugin": "1.6.1",
		"console-fail-test": "0.6.1",
		"cspell": "10.0.0",
		"eslint": "10.7.0",
		"eslint-plugin-jsdoc": "63.1.0",
		"eslint-plugin-jsonc": "3.3.0",
		"eslint-plugin-n": "18.2.0",
		"eslint-plugin-package-json": "1.6.0",
		"eslint-plugin-perfectionist": "5.10.0",
		"eslint-plugin-regexp": "3.1.0",
		"eslint-plugin-yml": "3.6.0",
		"husky": "9.1.7",
		"knip": "6.27.0",
		"lint-staged": "17.0.2",
		"prettier": "3.9.0",
		"prettier-plugin-curly": "0.4.1",
		"prettier-plugin-packagejson": "3.0.0",
		"prettier-plugin-sentences-per-line": "0.2.0",
		"prettier-plugin-sh": "0.19.0",
		"release-it": "20.2.0",
		"tsdown": "0.22.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.64.0",
		"vitest": "4.1.0"
	},
	"packageManager": "pnpm@11.15.0",
	"engines": {
		"node": ">=18"
	},
	"publishConfig": {
		"provenance": true
	}
}
